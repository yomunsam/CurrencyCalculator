@page "/"
@inject ExchangeRateService ExchangeRateService
@inject LocalizationService LocalizationService
@inject BrowserStorageService BrowserStorageService

<PageTitle>@L("AppTitle")</PageTitle>

<section class="mb-4">
	<h1 class="h2 mb-2">@L("AppTitle")</h1>
	<p class="text-secondary mb-0">@L("AppSubtitle")</p>
</section>

<section class="card shadow-sm border-0 mb-4">
	<div class="card-body d-flex flex-wrap gap-3 align-items-center justify-content-between">
		<div class="d-flex flex-column gap-1">
			<div>
				<span class="text-secondary me-2">@L("RateSource")</span>
				<span class="badge @GetSourceBadgeClass()">@GetSourceLabel()</span>
			</div>
			@if (LatestSnapshot is not null)
			{
				<small class="text-secondary">@L("UpdatedAt"): @LatestSnapshot.FetchedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</small>
			}
		</div>

		<div class="d-flex gap-2 align-items-center flex-wrap">
			<label class="small text-secondary mb-0" for="lang-select">@L("Language")</label>
			<select id="lang-select" class="form-select form-select-sm lang-select" value="@CurrentLanguage" @onchange="OnLanguageChanged">
				@foreach (var language in LocalizationService.SupportedLanguages)
				{
					<option value="@language">@language</option>
				}
			</select>

			<button class="btn btn-outline-primary btn-sm" @onclick="RefreshRatesAsync" disabled="@IsLoading">
				<i class="bi bi-arrow-clockwise me-1"></i>@L("Refresh")
			</button>
		</div>
	</div>
</section>

@if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
	<div class="alert alert-warning" role="alert">@ErrorMessage</div>
}

<section class="mb-3 d-flex justify-content-between align-items-center gap-2 flex-wrap">
	<small class="text-secondary">@L("FocusedBaseHint")</small>
	<button class="btn btn-primary btn-sm" @onclick="AddItemAsync" disabled="@(CompareItems.Count >= AppSettings.MaxCompareItems)">
		<i class="bi bi-plus-circle me-1"></i>@L("AddItem")
	</button>
</section>

<section class="d-grid gap-3">
	@for (var i = 0; i < CompareItems.Count; i++)
	{
		var row = CompareItems[i];
		var rowIndex = i;
		var isActive = rowIndex == ActiveIndex;
		var currency = CurrencyCatalog.GetByCode(row.CurrencyCode);
		<article class="card border-0 shadow-sm compare-row @(isActive ? "is-active" : string.Empty)">
			<div class="card-body">
				<div class="row g-2 align-items-end">
					<div class="col-12 col-md-4">
						<label class="form-label small text-secondary">Currency</label>
						<select class="form-select" value="@row.CurrencyCode" @onfocus="() => SetActiveIndex(rowIndex)" @onchange="eventArgs => OnCurrencyChangedAsync(rowIndex, eventArgs)">
							@foreach (var item in CurrencyCatalog.Items)
							{
								<option value="@item.Code">@item.Code - @(CurrentLanguage == "zh-CN" ? item.NameZh : item.NameEn)</option>
							}
						</select>
					</div>

					<div class="col-12 col-md-6">
						<label class="form-label small text-secondary">Amount</label>
						<input class="form-control" type="number" step="any" value="@FormatAmount(row.Amount)" @onfocus="() => SetActiveIndex(rowIndex)" @oninput="eventArgs => OnAmountInputAsync(rowIndex, eventArgs)" />
					</div>

					<div class="col-12 col-md-2 text-md-end">
						<button class="btn btn-outline-danger w-100" @onclick="() => RemoveItemAsync(rowIndex)" disabled="@(CompareItems.Count <= AppSettings.MinCompareItems)">
							<i class="bi bi-trash me-1"></i>@L("Remove")
						</button>
					</div>
				</div>

				@if (!HasRate(row.CurrencyCode))
				{
					<small class="text-warning d-inline-block mt-2">@L("Unavailable") (@row.CurrencyCode)</small>
				}

				@if (isActive)
				{
					<span class="badge text-bg-primary mt-3">BASE</span>
				}
			</div>
		</article>
	}
</section>

@code {
	private string CurrentLanguage { get; set; } = "en-US";
	private List<CompareItemState> CompareItems { get; set; } = [];
	private ExchangeRatesSnapshot? LatestSnapshot { get; set; }
	private int ActiveIndex { get; set; }
	private bool IsLoading { get; set; }
	private string? ErrorMessage { get; set; }

	protected override async Task OnInitializedAsync()
	{
		CurrentLanguage = await LocalizationService.InitializeLanguageAsync();

		var preferences = await BrowserStorageService.GetAsync<UserPreferences>(AppSettings.PreferencesStorageKey);
		if (preferences is not null && preferences.Items.Count > 0)
		{
			CurrentLanguage = LocalizationService.Normalize(preferences.Language);
			CompareItems = EnsureValidCompareItems(preferences.Items);
			ActiveIndex = Math.Clamp(preferences.ActiveIndex, 0, CompareItems.Count - 1);
		}
		else
		{
			CompareItems = BuildDefaultItems(CurrentLanguage);
			ActiveIndex = 0;
		}

		await LoadRatesAsync(forceRefresh: false);
		RecalculateFromActive();
		await SavePreferencesAsync();
	}

	private async Task RefreshRatesAsync()
	{
		await LoadRatesAsync(forceRefresh: true);
		RecalculateFromActive();
		await SavePreferencesAsync();
	}

	private async Task LoadRatesAsync(bool forceRefresh)
	{
		IsLoading = true;
		ErrorMessage = null;
		try
		{
			LatestSnapshot = await ExchangeRateService.GetLatestAsync(forceRefresh);
		}
		catch
		{
			ErrorMessage = L("LoadFailed");
		}
		finally
		{
			IsLoading = false;
		}
	}

	private void SetActiveIndex(int index)
	{
		ActiveIndex = Math.Clamp(index, 0, CompareItems.Count - 1);
		RecalculateFromActive();
	}

	private async Task OnAmountInputAsync(int index, ChangeEventArgs eventArgs)
	{
		if (!TryParseAmount(eventArgs.Value?.ToString(), out var amount))
		{
			return;
		}

		SetActiveIndex(index);
		CompareItems[index].Amount = amount;
		RecalculateFromActive();
		await SavePreferencesAsync();
	}

	private async Task OnCurrencyChangedAsync(int index, ChangeEventArgs eventArgs)
	{
		var selected = eventArgs.Value?.ToString()?.Trim().ToUpperInvariant();
		if (string.IsNullOrWhiteSpace(selected) || !CurrencyCatalog.IsSupported(selected))
		{
			return;
		}

		CompareItems[index].CurrencyCode = selected;
		RecalculateFromActive();
		await SavePreferencesAsync();
	}

	private async Task AddItemAsync()
	{
		if (CompareItems.Count >= AppSettings.MaxCompareItems)
		{
			return;
		}

		var nextCurrency = CurrencyCatalog.Items
			.Select(item => item.Code)
			.FirstOrDefault(code => CompareItems.All(existing => !existing.CurrencyCode.Equals(code, StringComparison.OrdinalIgnoreCase)))
			?? "USD";

		var nextItem = new CompareItemState
		{
			CurrencyCode = nextCurrency,
			Amount = 0m
		};

		CompareItems.Add(nextItem);
		RecalculateFromActive();
		await SavePreferencesAsync();
	}

	private async Task RemoveItemAsync(int index)
	{
		if (CompareItems.Count <= AppSettings.MinCompareItems)
		{
			return;
		}

		CompareItems.RemoveAt(index);
		if (ActiveIndex >= CompareItems.Count)
		{
			ActiveIndex = CompareItems.Count - 1;
		}

		RecalculateFromActive();
		await SavePreferencesAsync();
	}

	private async Task OnLanguageChanged(ChangeEventArgs eventArgs)
	{
		var language = LocalizationService.Normalize(eventArgs.Value?.ToString());
		CurrentLanguage = language;
		await LocalizationService.SaveLanguageAsync(language);
		await SavePreferencesAsync();
	}

	private void RecalculateFromActive()
	{
		if (LatestSnapshot is null || CompareItems.Count == 0)
		{
			return;
		}

		ActiveIndex = Math.Clamp(ActiveIndex, 0, CompareItems.Count - 1);
		var baseItem = CompareItems[ActiveIndex];

		foreach (var (item, index) in CompareItems.Select((item, index) => (item, index)))
		{
			if (index == ActiveIndex)
			{
				continue;
			}

			if (!HasRate(baseItem.CurrencyCode) || !HasRate(item.CurrencyCode))
			{
				continue;
			}

			var converted = ExchangeRateService.Convert(baseItem.Amount, baseItem.CurrencyCode, item.CurrencyCode, LatestSnapshot);
			item.Amount = decimal.Round(converted, item.CurrencyCode is "BTC" or "ETH" ? 8 : 4);
		}
	}

	private async Task SavePreferencesAsync()
	{
		var preferences = new UserPreferences
		{
			Language = CurrentLanguage,
			ActiveIndex = ActiveIndex,
			Items = CompareItems
				.Select(item => new CompareItemState { CurrencyCode = item.CurrencyCode, Amount = item.Amount })
				.ToList()
		};

		await BrowserStorageService.SetAsync(AppSettings.PreferencesStorageKey, preferences);
	}

	private List<CompareItemState> EnsureValidCompareItems(List<CompareItemState> items)
	{
		var validItems = items
			.Where(item => CurrencyCatalog.IsSupported(item.CurrencyCode))
			.Take(AppSettings.MaxCompareItems)
			.Select(item => new CompareItemState { CurrencyCode = item.CurrencyCode.ToUpperInvariant(), Amount = item.Amount })
			.ToList();

		if (validItems.Count < AppSettings.MinCompareItems)
		{
			validItems = BuildDefaultItems(CurrentLanguage);
		}

		return validItems;
	}

	private List<CompareItemState> BuildDefaultItems(string language)
	{
		var defaults = LocalizationService.GetDefaultCurrencyCodes(language);
		return
		[
			new CompareItemState { CurrencyCode = defaults[0], Amount = 100m },
			new CompareItemState { CurrencyCode = defaults[1], Amount = 0m }
		];
	}

	private bool HasRate(string code)
	{
		return LatestSnapshot?.HasRate(code) == true;
	}

	private string L(string key) => LocalizationService.T(CurrentLanguage, key);

	private string GetSourceLabel()
	{
		if (LatestSnapshot is null)
		{
			return "-";
		}

		return LatestSnapshot.SourceKind switch
		{
			ExchangeRatesSourceKind.LiveApi => L("Live"),
			ExchangeRatesSourceKind.LocalCache => L("Cache"),
			ExchangeRatesSourceKind.StaticFallback => L("Fallback"),
			_ => LatestSnapshot.Source
		};
	}

	private string GetSourceBadgeClass()
	{
		return LatestSnapshot?.SourceKind switch
		{
			ExchangeRatesSourceKind.LiveApi => "text-bg-success",
			ExchangeRatesSourceKind.LocalCache => "text-bg-warning",
			ExchangeRatesSourceKind.StaticFallback => "text-bg-secondary",
			_ => "text-bg-light"
		};
	}

	private static bool TryParseAmount(string? input, out decimal amount)
	{
		return decimal.TryParse(input, System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out amount)
			   || decimal.TryParse(input, out amount);
	}

	private static string FormatAmount(decimal amount)
	{
		return amount.ToString(System.Globalization.CultureInfo.InvariantCulture);
	}
}
