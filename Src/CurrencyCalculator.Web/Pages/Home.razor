@page "/"
@inject ExchangeRateService ExchangeRateService
@inject LocalizationService LocalizationService
@inject BrowserStorageService BrowserStorageService
@inject IJSRuntime JS

<PageTitle>@L("AppTitle")</PageTitle>

@* ════════ Header (title + dark mode only) ════════ *@
<header class="app-header">
    <div class="d-flex align-items-center justify-content-center px-2 py-2 position-relative">
        <span class="header-title">@L("AppTitle")</span>
        <button class="header-btn position-absolute" style="right:.5rem;"
                @onclick="ToggleThemeAsync" title="Toggle theme">
            <i class="bi @(IsDarkMode ? "bi-sun" : "bi-moon")"></i>
        </button>
    </div>
</header>

@* ════════ Ad banner placeholder (top) — hidden by default ════════ *@
<div class="cc-ad-slot cc-ad-top d-none" aria-hidden="true">
    <!-- Ad banner top -->
</div>

@* ════════ Subtitle ════════ *@
<p class="text-center mt-2 mb-3" style="font-size:.8rem;color:var(--cc-text-secondary);">
    @L("AppSubtitle")
</p>

@* ════════ Error ════════ *@
@if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert alert-warning py-2 px-3" style="font-size:.85rem;" role="alert">@ErrorMessage</div>
}

@* ════════ Currency rows ════════ *@
<section class="d-flex flex-column gap-2 mb-2">
    @for (var i = 0; i < CompareItems.Count; i++)
    {
        var row = CompareItems[i];
        var rowIndex = i;
        var isActive = rowIndex == ActiveIndex;
        var currency = CurrencyCatalog.GetByCode(row.CurrencyCode);
        var isCrypto = currency.Kind == CurrencyKind.Crypto;
        var isCryptoStale = IsCryptoStale(currency);

        <div class="cc-row @(isActive ? "is-active" : "")"
             @onclick="() => SetActiveIndex(rowIndex)">

            @* Icon — flag image for fiat, styled text for crypto *@
            @if (currency.Kind == CurrencyKind.Fiat)
            {
                <img class="currency-flag" src="https://flagcdn.com/w40/@(currency.Icon).png"
                     alt="@currency.Code" loading="lazy" />
            }
            else
            {
                <span class="currency-icon-crypto">@currency.Icon</span>
            }

            @* Code + Name area — clicking code opens selector *@
            <div class="currency-info" style="width:4.5rem;">
                <span class="currency-code" @onclick="() => OpenSelector(rowIndex)" @onclick:stopPropagation="true">
                    @currency.Code <i class="bi bi-chevron-down" style="font-size:.6rem;"></i>
                </span>
                <span class="currency-name">@currency.GetName(CurrentLanguage)</span>
            </div>

            @* Crypto warning icon: yellow = stale (>1h), blue = volatile (always for crypto) *@
            @if (isCrypto)
            {
                @if (isCryptoStale)
                {
                    <i class="bi bi-exclamation-triangle-fill crypto-warn-stale"
                       @onclick="() => ShowCryptoWarning(true)" @onclick:stopPropagation="true"></i>
                }
                else
                {
                    <i class="bi bi-exclamation-circle-fill crypto-warn-volatile"
                       @onclick="() => ShowCryptoWarning(false)" @onclick:stopPropagation="true"></i>
                }
            }

            @* Amount input *@
            <input class="amount-input" type="text" inputmode="decimal"
                   value="@GetDisplayAmount(row, currency)"
                   placeholder="0"
                   @onfocus="() => OnRowFocus(rowIndex)"
                   @onblur="eventArgs => OnAmountBlurAsync(rowIndex, eventArgs)"
                   @oninput="eventArgs => OnAmountInputAsync(rowIndex, eventArgs)" />

            @* Active row: clear button; otherwise: remove button *@
            @if (isActive)
            {
                <button class="row-btn" @onclick="() => ClearAmountAsync(rowIndex)" @onclick:stopPropagation="true"
                        title="@L("Clear")">
                    <i class="bi bi-eraser"></i>
                </button>
            }
            else
            {
                <button class="row-btn" @onclick="() => RemoveItemAsync(rowIndex)" @onclick:stopPropagation="true"
                        disabled="@(CompareItems.Count <= AppSettings.MinCompareItems)"
                        title="@L("Remove")">
                    <i class="bi bi-x-lg"></i>
                </button>
            }
        </div>
    }

    @* Add row *@
    <button class="cc-add-row" @onclick="AddItemAsync"
            disabled="@(CompareItems.Count >= AppSettings.MaxCompareItems)">
        <i class="bi bi-plus-circle"></i>
    </button>
</section>

@* ════════ Ad banner placeholder (bottom) — hidden by default ════════ *@
<div class="cc-ad-slot cc-ad-bottom d-none" aria-hidden="true">
    <!-- Ad banner bottom -->
</div>

@* ════════ Footer ════════ *@
<footer class="cc-footer mt-3 mb-2">
    @* Rate info *@
    @if (LatestSnapshot is not null)
    {
        var isGlobalStale = IsGlobalStale();
        <div class="cc-footer-info">
            <span>@L("RateSource"): <b>@GetSourceLabel()</b></span>
            <span class="mx-1">·</span>
            <span class="@(isGlobalStale ? "stale fw-semibold" : "")">
                @L("UpdatedAt"): @LatestSnapshot.FetchedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
            </span>
        </div>
        @if (isGlobalStale)
        {
            <div class="cc-footer-info stale">@L("StaleWarning")</div>
        }
    }

    @* Action buttons *@
    <div class="cc-footer-actions mt-2">
        <div class="position-relative d-inline-block">
            <button class="footer-btn" @onclick="ToggleLanguageMenu" @onclick:stopPropagation="true" title="@L("Language")">
                <i class="bi bi-translate"></i>
                <span>@GetLanguageLabel()</span>
                <i class="bi bi-chevron-up" style="font-size:.6rem;"></i>
            </button>
            @if (ShowLanguageMenu)
            {
                <div class="cc-lang-menu">
                    @foreach (var lang in LocalizationService.Languages)
                    {
                        <button class="cc-lang-menu-item @(lang.Code == CurrentLanguage ? "active" : "")"
                                @onclick="() => SwitchLanguageAsync(lang.Code)">
                            @lang.DisplayName
                        </button>
                    }
                </div>
            }
        </div>
        <button class="footer-btn @(IsRefreshing ? "refreshing" : "")" @onclick="RefreshRatesAsync" disabled="@IsLoading" title="@L("Refresh")">
            <i class="bi bi-arrow-clockwise"></i>
            <span>@L("Refresh")</span>
        </button>
        <button class="footer-btn" @onclick="() => ShowAbout = true" title="@L("AboutTitle")">
            <i class="bi bi-info-circle"></i>
            <span>@L("AboutTitle")</span>
        </button>
    </div>

    @* Copyright *@
    <div class="cc-copyright mt-2">@L("Copyright")</div>
</footer>

@* ════════ Currency Selector Overlay ════════ *@
@if (SelectorOpen)
{
    <div class="cc-selector-backdrop" @onclick="CloseSelector">
        <div class="cc-selector" @onclick:stopPropagation="true">
            @foreach (var item in CurrencyCatalog.Items)
            {
                <button class="cc-selector-item" @onclick="() => SelectCurrencyAsync(item.Code)">
                    @if (item.Kind == CurrencyKind.Fiat)
                    {
                        <img class="si-flag" src="https://flagcdn.com/w40/@(item.Icon).png" alt="@item.Code" loading="lazy" />
                    }
                    else
                    {
                        <span class="si-crypto">@item.Icon</span>
                    }
                    <span class="si-code">@item.Code</span>
                    <span class="si-name">@item.GetName(CurrentLanguage)</span>
                </button>
            }
        </div>
    </div>
}

@* ════════ About Modal ════════ *@
@if (ShowAbout)
{
    <div class="cc-modal-backdrop" @onclick="() => ShowAbout = false">
        <div class="cc-modal cc-modal-about" @onclick:stopPropagation="true">
            <button class="close-btn" @onclick="() => ShowAbout = false"><i class="bi bi-x-lg"></i></button>

            @* Section: About *@
            <h2>@L("AboutTitle")</h2>
            <p class="about-text">@L("AboutDesc")</p>

            @* Section: Data Sources *@
            <h3 class="about-section-title">@L("AboutDataSources")</h3>
            <ul class="about-list">
                <li>
                    <i class="bi bi-github me-1"></i>
                    <a href="https://github.com/fawazahmed0/exchange-api" target="_blank" rel="noreferrer">fawazahmed0/exchange-api</a>
                </li>
                <li>
                    <a href="https://www.frankfurter.app/" target="_blank" rel="noreferrer">Frankfurter</a>
                </li>
            </ul>

            @* Section: Tech Stack *@
            <h3 class="about-section-title">@L("AboutTechStack")</h3>
            <div class="about-tags">
                <span class="about-tag">Blazor WebAssembly</span>
                <span class="about-tag">.NET 10</span>
                <span class="about-tag">PWA</span>
                <span class="about-tag">GitHub Actions</span>
            </div>

            @* Section: AI Disclosure *@
            <h3 class="about-section-title">@L("AboutAIDisclosure")</h3>
            <p class="about-text">@L("AboutAIDisclosureText")</p>

            @* Section: Disclaimer *@
            <h3 class="about-section-title">@L("AboutDisclaimer")</h3>
            <ol class="about-disclaimer">
                <li>@L("AboutDisclaimer1")</li>
                <li>@L("AboutDisclaimer2")</li>
                <li>@L("AboutDisclaimer3")</li>
            </ol>

            @* Developer + repo *@
            <div class="about-footer">
                <p>
                    <i class="bi bi-person me-1"></i>@L("AboutDeveloper"): Yomu
                </p>
                <a href="https://github.com/yomunsam/CurrencyCalculator" target="_blank" rel="noreferrer">
                    <i class="bi bi-github me-1"></i>@L("AboutGitHub")
                </a>
            </div>
        </div>
    </div>
}

@* ════════ Crypto Warning Modal ════════ *@
@if (ShowCryptoModal)
{
    <div class="cc-modal-backdrop" @onclick="() => ShowCryptoModal = false">
        <div class="cc-modal cc-modal-sm" @onclick:stopPropagation="true">
            <button class="close-btn" @onclick="() => ShowCryptoModal = false"><i class="bi bi-x-lg"></i></button>
            <p style="font-size:.9rem;margin:0;">@CryptoModalMessage</p>
        </div>
    </div>
}

@* ════════ Language Menu Backdrop (click outside to close) ════════ *@
@if (ShowLanguageMenu)
{
    <div class="cc-lang-backdrop" @onclick="() => ShowLanguageMenu = false"></div>
}

@code {
    // ── State ──────────────────────────────────────────────────────────
    private string CurrentLanguage { get; set; } = "en-US";
    private List<CompareItemState> CompareItems { get; set; } = [];
    private ExchangeRatesSnapshot? LatestSnapshot { get; set; }
    private int ActiveIndex { get; set; }
    private bool IsLoading { get; set; }
    private bool IsRefreshing { get; set; }
    private string? ErrorMessage { get; set; }
    private bool IsDarkMode { get; set; }
    private bool ShowAbout { get; set; }
    private bool ShowLanguageMenu { get; set; }
    private bool ShowCryptoModal { get; set; }
    private string CryptoModalMessage { get; set; } = "";
    private bool SelectorOpen { get; set; }
    private int SelectorTargetIndex { get; set; }
    /// <summary>Index of the row the user is actively editing (typing into).</summary>
    private int? EditingRowIndex { get; set; }
    /// <summary>Raw text the user has typed while editing (before formatting).</summary>
    private string? RawEditingInput { get; set; }

    // ── Lifecycle ──────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        // Detect language from storage or browser preference
        CurrentLanguage = await LocalizationService.InitializeLanguageAsync();
        IsDarkMode = await JS.InvokeAsync<bool>("ccTheme.isDark");

        // Restore user preferences (comparison items, active index, language)
        var preferences = await BrowserStorageService.GetAsync<UserPreferences>(AppSettings.PreferencesStorageKey);
        if (preferences is not null && preferences.Items.Count > 0)
        {
            CurrentLanguage = LocalizationService.Normalize(preferences.Language);
            CompareItems = EnsureValidCompareItems(preferences.Items);
            ActiveIndex = Math.Clamp(preferences.ActiveIndex, 0, CompareItems.Count - 1);
        }
        else
        {
            CompareItems = BuildDefaultItems(CurrentLanguage);
            ActiveIndex = 0;
        }

        // Always try live API first on page load
        await LoadRatesAsync(forceRefresh: true);
        RecalculateFromActive();
        await SavePreferencesAsync();
    }

    // ── Rates ──────────────────────────────────────────────────────────
    /// <summary>Manual refresh with animation + toast feedback.</summary>
    private async Task RefreshRatesAsync()
    {
        IsRefreshing = true;
        StateHasChanged();
        await LoadRatesAsync(forceRefresh: true);
        RecalculateFromActive();
        await SavePreferencesAsync();

        // Toast feedback to indicate success or failure
        if (string.IsNullOrWhiteSpace(ErrorMessage))
        {
            await JS.InvokeVoidAsync("ccToast.show", L("RefreshSuccess"), 2000);
        }
        else
        {
            await JS.InvokeVoidAsync("ccToast.show", L("RefreshFailed"), 3000);
        }

        // Keep spin animation visible briefly so user perceives it
        _ = Task.Delay(600).ContinueWith(_ =>
        {
            IsRefreshing = false;
            InvokeAsync(StateHasChanged);
        });
    }

    /// <summary>Load rates via the ExchangeRateService (online → cache → fallback).</summary>
    private async Task LoadRatesAsync(bool forceRefresh)
    {
        IsLoading = true;
        ErrorMessage = null;
        try
        {
            LatestSnapshot = await ExchangeRateService.GetLatestAsync(forceRefresh);
        }
        catch
        {
            ErrorMessage = L("LoadFailed");
        }
        finally
        {
            IsLoading = false;
        }
    }

    // ── Row focus / input ──────────────────────────────────────────────
    /// <summary>When a row's input gains focus, mark it as the active editing row.</summary>
    private void OnRowFocus(int index)
    {
        SetActiveIndex(index);
        EditingRowIndex = index;
        // Show the raw numeric value (no thousand separators) for easy editing
        RawEditingInput = FormatAmountRaw(CompareItems[index].Amount, CurrencyCatalog.GetByCode(CompareItems[index].CurrencyCode));
    }

    /// <summary>Switch the active (base currency) row. Recalculates all other rows.</summary>
    private void SetActiveIndex(int index)
    {
        if (ActiveIndex == index) return;
        EditingRowIndex = null;
        RawEditingInput = null;
        ActiveIndex = Math.Clamp(index, 0, CompareItems.Count - 1);
        RecalculateFromActive();
    }

    /// <summary>
    /// Handle real-time input. Parse the value (supporting math expressions),
    /// update the active row amount, and recalculate all other rows.
    /// </summary>
    private async Task OnAmountInputAsync(int index, ChangeEventArgs eventArgs)
    {
        var raw = eventArgs.Value?.ToString() ?? "";
        EditingRowIndex = index;
        RawEditingInput = raw;

        if (!TryParseAmount(raw, out var amount))
            return;

        ActiveIndex = Math.Clamp(index, 0, CompareItems.Count - 1);
        CompareItems[index].Amount = amount;
        RecalculateFromActive();
        await SavePreferencesAsync();
    }

    /// <summary>
    /// On blur, finalize math expression evaluation and clear editing state.
    /// </summary>
    private async Task OnAmountBlurAsync(int index, FocusEventArgs _)
    {
        if (EditingRowIndex == index && RawEditingInput is not null)
        {
            if (MathExpressionEvaluator.TryEvaluate(RawEditingInput, out var result))
            {
                CompareItems[index].Amount = result;
                RecalculateFromActive();
                await SavePreferencesAsync();
            }
        }
        EditingRowIndex = null;
        RawEditingInput = null;
    }

    /// <summary>Clear the amount of the specified row to 0 and recalculate.</summary>
    private async Task ClearAmountAsync(int index)
    {
        CompareItems[index].Amount = 0m;
        EditingRowIndex = null;
        RawEditingInput = null;
        RecalculateFromActive();
        await SavePreferencesAsync();
    }

    // ── Currency selection ─────────────────────────────────────────────
    private void OpenSelector(int index)
    {
        SelectorTargetIndex = index;
        SelectorOpen = true;
    }

    private void CloseSelector() => SelectorOpen = false;

    /// <summary>Select a currency for the target row. Warns on duplicates.</summary>
    private async Task SelectCurrencyAsync(string code)
    {
        SelectorOpen = false;
        CompareItems[SelectorTargetIndex].CurrencyCode = code;

        if (CompareItems.Count(item => item.CurrencyCode.Equals(code, StringComparison.OrdinalIgnoreCase)) > 1)
        {
            await JS.InvokeVoidAsync("ccToast.show", L("DuplicateCurrency"), 3000);
        }

        RecalculateFromActive();
        await SavePreferencesAsync();
    }

    // ── Add / Remove ───────────────────────────────────────────────────
    /// <summary>Add a new comparison row with the first unused currency.</summary>
    private async Task AddItemAsync()
    {
        if (CompareItems.Count >= AppSettings.MaxCompareItems) return;
        var nextCurrency = CurrencyCatalog.Items
            .Select(item => item.Code)
            .FirstOrDefault(code => CompareItems.All(e => !e.CurrencyCode.Equals(code, StringComparison.OrdinalIgnoreCase)))
            ?? "USD";
        CompareItems.Add(new CompareItemState { CurrencyCode = nextCurrency, Amount = 0m });
        RecalculateFromActive();
        await SavePreferencesAsync();
    }

    /// <summary>Remove a comparison row (min items enforced).</summary>
    private async Task RemoveItemAsync(int index)
    {
        if (CompareItems.Count <= AppSettings.MinCompareItems) return;
        CompareItems.RemoveAt(index);
        if (ActiveIndex >= CompareItems.Count)
            ActiveIndex = CompareItems.Count - 1;
        RecalculateFromActive();
        await SavePreferencesAsync();
    }

    // ── Theme ──────────────────────────────────────────────────────────
    private async Task ToggleThemeAsync()
    {
        IsDarkMode = !IsDarkMode;
        await JS.InvokeVoidAsync("ccTheme.set", IsDarkMode ? "dark" : "light");
    }

    // ── Language ───────────────────────────────────────────────────────
    private void ToggleLanguageMenu() => ShowLanguageMenu = !ShowLanguageMenu;

    /// <summary>Switch to a specific language from the popup menu.</summary>
    private async Task SwitchLanguageAsync(string langCode)
    {
        ShowLanguageMenu = false;
        if (CurrentLanguage == langCode) return;
        CurrentLanguage = langCode;
        await LocalizationService.SaveLanguageAsync(CurrentLanguage);
        await SavePreferencesAsync();
    }

    private string GetLanguageLabel()
    {
        var entry = LocalizationService.GetLanguageEntry(CurrentLanguage);
        return entry?.DisplayName ?? CurrentLanguage;
    }

    // ── Crypto warning ─────────────────────────────────────────────────
    /// <summary>Show a small modal explaining the crypto icon meaning.</summary>
    private void ShowCryptoWarning(bool isStale)
    {
        CryptoModalMessage = isStale ? L("CryptoStaleWarning") : L("CryptoVolatileWarning");
        ShowCryptoModal = true;
    }

    // ── Recalculation ──────────────────────────────────────────────────
    /// <summary>
    /// Convert all non-active rows based on the active row's amount.
    /// Uses the "cross-rate via USD" approach: amount_target = amount_base / rate_base * rate_target.
    /// This is standard for most retail FX and sufficiently accurate for consumer use.
    /// </summary>
    private void RecalculateFromActive()
    {
        if (LatestSnapshot is null || CompareItems.Count == 0) return;
        ActiveIndex = Math.Clamp(ActiveIndex, 0, CompareItems.Count - 1);
        var baseItem = CompareItems[ActiveIndex];

        for (var i = 0; i < CompareItems.Count; i++)
        {
            if (i == ActiveIndex) continue;
            var item = CompareItems[i];
            if (!HasRate(baseItem.CurrencyCode) || !HasRate(item.CurrencyCode)) continue;
            var converted = ExchangeRateService.Convert(baseItem.Amount, baseItem.CurrencyCode, item.CurrencyCode, LatestSnapshot);
            var def = CurrencyCatalog.GetByCode(item.CurrencyCode);
            item.Amount = decimal.Round(converted, def.DisplayDecimals);
        }
    }

    // ── Display helpers ────────────────────────────────────────────────
    /// <summary>
    /// Returns the display value for a row's amount input.
    /// During editing: shows localized formatting of what user typed (with thousand separators).
    /// When not editing: shows the formatted amount.
    /// </summary>
    private string GetDisplayAmount(CompareItemState row, CurrencyDefinition currency)
    {
        var rowIndex = CompareItems.IndexOf(row);
        // During editing, try to localize the raw input if it's a clean number
        if (EditingRowIndex == rowIndex && RawEditingInput is not null)
            return FormatEditingInput(RawEditingInput, currency);
        return FormatAmountForDisplay(row.Amount, currency);
    }

    /// <summary>Format a finalized amount with locale-appropriate thousand separators and decimals.</summary>
    private string FormatAmountForDisplay(decimal amount, CurrencyDefinition currency)
    {
        if (amount == 0m) return "";
        var culture = GetCultureForLanguage();
        return amount.ToString($"N{currency.DisplayDecimals}", culture);
    }

    /// <summary>
    /// Format the raw input during editing. If the input is a plain number,
    /// apply thousand separators while preserving trailing decimals/dots.
    /// If it contains operators (math expression), show as-is.
    /// </summary>
    private string FormatEditingInput(string raw, CurrencyDefinition currency)
    {
        if (string.IsNullOrEmpty(raw)) return "";

        // If it contains math operators, don't localize — show as-is
        if (raw.AsSpan().ContainsAny("+-*/()"))
            return raw;

        // Strip existing thousand separators for re-formatting
        var cleaned = raw.Replace(",", "").Replace(" ", "").Replace("_", "");

        // Preserve trailing dot or trailing zeros after dot (user is still typing decimals)
        var dotIndex = cleaned.IndexOf('.');
        var hasTrailingDot = cleaned.EndsWith('.');
        string? decimalSuffix = null;

        if (dotIndex >= 0 && !hasTrailingDot)
        {
            decimalSuffix = cleaned[dotIndex..]; // e.g. ".50" or ".5"
        }

        if (decimal.TryParse(cleaned, System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out var number))
        {
            var culture = GetCultureForLanguage();
            var separator = culture.NumberFormat.NumberGroupSeparator;

            if (hasTrailingDot)
            {
                // Format integer part, append dot
                return number.ToString("N0", culture) + ".";
            }
            else if (decimalSuffix is not null)
            {
                // Format integer part, keep original decimal suffix
                var intPart = decimal.Truncate(number);
                return intPart.ToString("N0", culture) + decimalSuffix;
            }
            else
            {
                // Pure integer — format with thousand separators, no decimals
                return number.ToString("N0", culture);
            }
        }

        return raw;
    }

    private static string FormatAmountRaw(decimal amount, CurrencyDefinition currency)
    {
        if (amount == 0m) return "";
        return amount.ToString(System.Globalization.CultureInfo.InvariantCulture);
    }

    /// <summary>Map the current language to a .NET CultureInfo for number formatting.</summary>
    private System.Globalization.CultureInfo GetCultureForLanguage() => CurrentLanguage switch
    {
        "zh-CN" => new System.Globalization.CultureInfo("zh-CN"),
        "ja-JP" => new System.Globalization.CultureInfo("ja-JP"),
        "en-US" => new System.Globalization.CultureInfo("en-US"),
        _ => System.Globalization.CultureInfo.InvariantCulture
    };

    private bool HasRate(string code) => LatestSnapshot?.HasRate(code) == true;
    private string L(string key) => LocalizationService.T(CurrentLanguage, key);

    // ── Stale detection ────────────────────────────────────────────────
    /// <summary>True if the overall rate data is older than the fiat stale threshold (24h).</summary>
    private bool IsGlobalStale()
    {
        if (LatestSnapshot is null) return false;
        return (DateTimeOffset.UtcNow - LatestSnapshot.FetchedAtUtc) > AppSettings.FiatStaleThreshold;
    }

    /// <summary>True if a crypto currency's rate data is older than the crypto stale threshold (1h).</summary>
    private bool IsCryptoStale(CurrencyDefinition currency)
    {
        if (currency.Kind != CurrencyKind.Crypto || LatestSnapshot is null) return false;
        return (DateTimeOffset.UtcNow - LatestSnapshot.FetchedAtUtc) > AppSettings.CryptoStaleThreshold;
    }

    private string GetSourceLabel() => LatestSnapshot?.SourceKind switch
    {
        ExchangeRatesSourceKind.LiveApi => L("Live"),
        ExchangeRatesSourceKind.LocalCache => L("Cache"),
        ExchangeRatesSourceKind.StaticFallback => L("Fallback"),
        _ => "-"
    };

    // ── Persistence ────────────────────────────────────────────────────
    /// <summary>Save user preferences (language, active index, comparison items) to localStorage.</summary>
    private async Task SavePreferencesAsync()
    {
        var preferences = new UserPreferences
        {
            Language = CurrentLanguage,
            ActiveIndex = ActiveIndex,
            Items = CompareItems
                .Select(item => new CompareItemState { CurrencyCode = item.CurrencyCode, Amount = item.Amount })
                .ToList()
        };
        await BrowserStorageService.SetAsync(AppSettings.PreferencesStorageKey, preferences);
    }

    /// <summary>Validate saved comparison items against the current currency catalog.</summary>
    private List<CompareItemState> EnsureValidCompareItems(List<CompareItemState> items)
    {
        var valid = items
            .Where(item => CurrencyCatalog.IsSupported(item.CurrencyCode))
            .Take(AppSettings.MaxCompareItems)
            .Select(item => new CompareItemState { CurrencyCode = item.CurrencyCode.ToUpperInvariant(), Amount = item.Amount })
            .ToList();
        return valid.Count >= AppSettings.MinCompareItems ? valid : BuildDefaultItems(CurrentLanguage);
    }

    /// <summary>Build default comparison rows based on the language's preferred currencies.</summary>
    private List<CompareItemState> BuildDefaultItems(string language)
    {
        var defaults = LocalizationService.GetDefaultCurrencyCodes(language);
        return
        [
            new CompareItemState { CurrencyCode = defaults[0], Amount = 100m },
            new CompareItemState { CurrencyCode = defaults[1], Amount = 0m }
        ];
    }

    /// <summary>Parse user input as a decimal amount, supporting math expressions.</summary>
    private static bool TryParseAmount(string? input, out decimal amount)
    {
        amount = 0m;
        if (string.IsNullOrWhiteSpace(input)) return false;
        if (MathExpressionEvaluator.TryEvaluate(input, out amount)) return true;
        return false;
    }
}
