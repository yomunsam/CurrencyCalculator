<div class="cc-row @(IsActive ? "is-active" : "") @(IsDragPending ? "is-drag-pending" : "") @(IsDragging ? "is-dragging" : "")"
     @onclick="OnSetActive"
     @onpointerenter="OnDragEnter">
    <button class="row-drag-handle" title="Reorder"
            @onpointerdown="OnDragPointerDown"
            @onpointermove="OnDragPointerMove"
            @onpointerup="OnDragPointerUp"
            @onpointercancel="OnDragPointerCancel"
            @onpointerdown:preventDefault="true"
            @onclick:stopPropagation="true">
        <i class="bi bi-grip-vertical"></i>
    </button>

    @if (Currency.Kind == CurrencyKind.Fiat)
    {
        <img class="currency-flag" src="https://flagcdn.com/w40/@(Currency.Icon).png"
             alt="@Currency.Code" loading="lazy" />
    }
    else
    {
        <span class="currency-icon-crypto">@Currency.Icon</span>
    }

    <div class="currency-info" style="width:4.5rem;">
        <span class="currency-code" @onclick="OnOpenSelector" @onclick:stopPropagation="true">
            @Currency.Code <i class="bi bi-chevron-down" style="font-size:.6rem;"></i>
        </span>
        <span class="currency-name">@Currency.GetName(CurrentLanguage)</span>
    </div>

    @if (Currency.Kind == CurrencyKind.Crypto)
    {
        @if (IsCryptoStale)
        {
            <i class="bi bi-exclamation-triangle-fill crypto-warn-stale"
               @onclick="() => OnShowCryptoWarning.InvokeAsync(true)" @onclick:stopPropagation="true"></i>
        }
        else
        {
            <i class="bi bi-exclamation-circle-fill crypto-warn-volatile"
               @onclick="() => OnShowCryptoWarning.InvokeAsync(false)" @onclick:stopPropagation="true"></i>
        }
    }

    <input class="amount-input" type="text" inputmode="decimal"
           value="@DisplayAmount"
           placeholder="0"
           @onfocus="OnFocus"
           @onblur="OnBlur"
           @oninput="OnInput" />

    @if (IsActive)
    {
        <button class="row-btn" @onclick="OnClear" @onclick:stopPropagation="true" title="@ClearTitle">
            <i class="bi bi-eraser"></i>
        </button>
    }
    else
    {
        <button class="row-btn" @onclick="OnRemove" @onclick:stopPropagation="true"
                disabled="@(!CanRemove)"
                title="@RemoveTitle">
            <i class="bi bi-x-lg"></i>
        </button>
    }
</div>

@code {
    [Parameter, EditorRequired] public CurrencyDefinition Currency { get; set; } = default!;
    [Parameter, EditorRequired] public string CurrentLanguage { get; set; } = "en-US";
    [Parameter, EditorRequired] public string DisplayAmount { get; set; } = "";
    [Parameter, EditorRequired] public string ClearTitle { get; set; } = "Clear";
    [Parameter, EditorRequired] public string RemoveTitle { get; set; } = "Remove";
    [Parameter] public bool IsActive { get; set; }
    [Parameter] public bool CanRemove { get; set; }
    [Parameter] public bool IsCryptoStale { get; set; }
    [Parameter] public bool IsDragPending { get; set; }
    [Parameter] public bool IsDragging { get; set; }

    [Parameter, EditorRequired] public EventCallback OnSetActive { get; set; }
    [Parameter, EditorRequired] public EventCallback OnOpenSelector { get; set; }
    [Parameter, EditorRequired] public EventCallback<bool> OnShowCryptoWarning { get; set; }
    [Parameter, EditorRequired] public EventCallback OnFocus { get; set; }
    [Parameter, EditorRequired] public EventCallback<FocusEventArgs> OnBlur { get; set; }
    [Parameter, EditorRequired] public EventCallback<ChangeEventArgs> OnInput { get; set; }
    [Parameter, EditorRequired] public EventCallback OnClear { get; set; }
    [Parameter, EditorRequired] public EventCallback OnRemove { get; set; }
    [Parameter, EditorRequired] public EventCallback<PointerEventArgs> OnDragPointerDown { get; set; }
    [Parameter, EditorRequired] public EventCallback<PointerEventArgs> OnDragPointerMove { get; set; }
    [Parameter, EditorRequired] public EventCallback<PointerEventArgs> OnDragPointerUp { get; set; }
    [Parameter, EditorRequired] public EventCallback<PointerEventArgs> OnDragPointerCancel { get; set; }
    [Parameter, EditorRequired] public EventCallback OnDragEnter { get; set; }
}
